{
  "name": "automec",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "turbo --filter=@automec/db db:generate",
    "db:migrate": "turbo --filter=@automec/db db:migrate",
    "db:push": "turbo --filter=@automec/db db:push",
    "db:seed": "turbo --filter=@automec/db db:seed",
    "db:studio": "turbo --filter=@automec/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "prettier": "^3.5.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0",
  "overrides": {
    "inotify": "file:./shims/inotify"
  }
}
